# ============================================================
# MEGA PACIFIC - Root .gitignore
# ============================================================

# -------------------------------------------------------
# ENVIRONMENT & SECRETS (NEVER commit these!)
# -------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.cert

# -------------------------------------------------------
# NODE.js / Backend
# -------------------------------------------------------
backend/node_modules/
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
package-lock.json
.npm

# -------------------------------------------------------
# Flutter / Dart / Frontend
# -------------------------------------------------------
# Dart tool artifacts
frontend/.dart_tool/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/.pub-cache/
frontend/.pub/
frontend/build/

# Generated files
frontend/**/doc/api/
frontend/**/ios/Flutter/.last_build_id

# Symbolication & obfuscation
frontend/app.*.symbols
frontend/app.*.map.json

# Android Studio build artifacts
frontend/android/app/debug
frontend/android/app/profile
frontend/android/app/release

# -------------------------------------------------------
# IDEs & Editors
# -------------------------------------------------------
# IntelliJ / Android Studio
*.iml
*.ipr
*.iws
.idea/

# VS Code
.vscode/

# Sublime Text
*.sublime-workspace

# -------------------------------------------------------
# Operating System Files
# -------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# -------------------------------------------------------
# Logs & Temporary Files
# -------------------------------------------------------
*.log
*.tmp
*.temp
*.swp
*.swo
.buildlog/
.history
.svn/
migrate_working_dir/

# -------------------------------------------------------
# Misc
# -------------------------------------------------------
*.class
*.pyc
